// CoTailor data model (design Section 17). PostgreSQL + Prisma.
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "queryCompiler"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionState {
  CREATED
  JD_SUBMITTED
  ANALYZING
  CATEGORY_REJECTED
  WAITING_CATEGORY_CONFIRMATION
  WAITING_SUBTYPE_CONFIRMATION
  WAITING_SKILL_DECISIONS
  STRATEGY_REVIEW
  GENERATING
  VALIDATING
  NEEDS_REVISION
  FINAL_READY
  REVISING
  CANCELLED
  EXPIRED
}

enum SkillPriority {
  required
  preferred
}

enum MatchType {
  exact
  equivalent
  similar_stack
  same_family
  missing
  blocked_sensitive
}

enum RiskLevel {
  none
  low
  medium
  high
  critical
}

enum CardType {
  category_mismatch
  category_low_confidence
  subtype_mismatch
  knockout_requirement
  missing_required_skill
  similar_skill
  certification_risk
  resume_style
  strategy_approval
}

enum CardSeverity {
  info
  warning
  blocking
  critical
}

enum CardStatus {
  pending
  answered
  auto_resolved
  expired
}

enum Provenance {
  profile_verified
  user_confirmed
  omitted
}

enum ResumeStyle {
  ats_strong
  recruiter_friendly
  balanced
}

enum CreatedBy {
  ai_generation
  ai_revision
  user_edit
}

enum ScreeningOutlook {
  likely_pass
  borderline
  unlikely
}

enum ExportFormat {
  docx
  pdf
  txt
}

enum CategoryRelationKind {
  same
  adjacent
  distinct
}

enum Role {
  user
  admin
}

// Lifecycle: signup -> pending (admin must approve) -> active <-> suspended.
enum UserStatus {
  pending
  active
  suspended
}

// User-selected UI theme; `system` follows the OS prefers-color-scheme.
enum ThemePref {
  light
  dark
  system
}

// Where LLM credentials come from. `own_keys` (BYO) is not yet enabled in the
// UI — the option is shown disabled until per-user key storage lands.
enum AiProviderMode {
  cotailor
  own_keys
}

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  name           String?
  passwordHash   String?
  role           Role               @default(user)
  status         UserStatus         @default(pending)
  theme          ThemePref          @default(system)
  aiProviderMode AiProviderMode     @default(cotailor)
  certSuggestionCount Int           @default(3) // how many certs the AI suggests per job (user setting)
  verifiedAt     DateTime? // when an admin approved the account
  disabledAt     DateTime? // when the current suspension started
  createdAt      DateTime           @default(now())
  profiles       Profile[]
  sessions       TailoringSession[]
  auditLogs      AuditLog[]
}

model Profile {
  id                String                 @id @default(cuid())
  userId            String
  user              User                   @relation(fields: [userId], references: [id])
  name              String
  category          String
  baseResume        Json
  domainTags        String[]
  workAuthorization String?
  deletedAt         DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  subtypes          ProfileSubtype[]
  skills            ProfileSkill[]
  certifications    ProfileCertification[]
  sessions          TailoringSession[]
  decisionMemory    DecisionMemory[]

  @@index([userId])
}

model ProfileSubtype {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String

  @@index([profileId])
}

model ProfileSkill {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  years     Int?

  @@index([profileId])
}

model ProfileCertification {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  issuer    String?
  catalogId String? // links to CertificationCatalog when picked from the catalog; null = custom entry

  @@index([profileId])
}

// Manager-curated certification library. The AI may only SELECT from these
// rows — it never invents a cert name. Filed under one category and many
// subtypes so one cert (e.g. AWS Solutions Architect) surfaces for Backend,
// DevOps, Cloud, etc. all at once.
model CertificationCatalog {
  id         String   @id @default(cuid())
  name       String // canonical display name
  issuer     String
  level      String? // foundational | associate | professional | specialty | single
  categories String[] // top-level buckets — a cert can belong to several (e.g. AWS ML: Data Science + Software Engineering)
  subtypes   String[] // subtypes this cert is relevant to (many)
  aliases    String[] // nicknames used for matching
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// A cert a user says they hold but couldn't find in the catalog. Becomes an
// item on the manager's to-do list to add to the catalog.
model CertificationTodo {
  id          String   @id @default(cuid())
  rawText     String // exactly what the user typed
  issuer      String?
  category    String?
  subtype     String?
  requestedBy String? // userId who requested it
  status      String   @default("open") // open | done | dismissed
  createdAt   DateTime @default(now())

  @@index([status])
}

// Manager-curated role taxonomy (2-level for now: Category -> Subtype; a
// `familyId` mid-level lands in a later version). Replaces the hard-coded
// CATEGORY_TAXONOMY / PROFILE_SUBTYPES constants — one managed source for the
// profile form, the JD-analysis prompt, and the cert pickers. Names are the
// stable keys (gates compare by name), so prefer disable/rename over delete.
model TaxonomyCategory {
  id        String            @id @default(cuid())
  name      String            @unique
  sortOrder Int               @default(100)
  enabled   Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  families  TaxonomyFamily[]
  subtypes  TaxonomySubtype[]
}

// Optional mid-level grouping inside a category. A subtype may live in a family
// or directly under the category (familyId null = "ungrouped").
model TaxonomyFamily {
  id         String            @id @default(cuid())
  categoryId String
  category   TaxonomyCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  sortOrder  Int               @default(100)
  enabled    Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  subtypes   TaxonomySubtype[]

  @@unique([categoryId, name])
  @@index([categoryId])
}

model TaxonomySubtype {
  id         String           @id @default(cuid())
  categoryId String
  category   TaxonomyCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  familyId   String?
  family     TaxonomyFamily?  @relation(fields: [familyId], references: [id], onDelete: SetNull)
  name       String
  sortOrder  Int              @default(100)
  enabled    Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([categoryId, name])
  @@index([categoryId])
  @@index([familyId])
}

model JdDocument {
  id          String             @id @default(cuid())
  userId      String?
  contentHash String             @unique
  text        String
  source      String             @default("paste")
  createdAt   DateTime           @default(now())
  sessions    TailoringSession[]
  analyses    JdAnalysis[]
}

model TailoringSession {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  profileId       String
  profile         Profile          @relation(fields: [profileId], references: [id])
  jdDocumentId    String?
  jdDocument      JdDocument?      @relation(fields: [jdDocumentId], references: [id])
  state           SessionState     @default(CREATED)
  profileSnapshot Json?
  activeVersionId String?
  revisionCount   Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  expiresAt       DateTime?
  analyses        JdAnalysis[]
  skillMatches    SkillMatch[]
  cards           DecisionCard[]
  decisions       UserDecision[]
  strategies      ResumeStrategy[]
  resume          GeneratedResume?
  versions        ResumeVersion[]
  chatMessages    ChatMessage[]
  auditLogs       AuditLog[]

  @@index([userId])
  @@index([state])
}

model JdAnalysis {
  id                 String       @id @default(cuid())
  sessionId          String
  session            TailoringSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  jdDocumentId       String
  jdDocument         JdDocument   @relation(fields: [jdDocumentId], references: [id])
  category           String
  categoryConfidence Float
  subtype            String
  subtypeConfidence  Float
  domainKeywords     String[]
  summary            String
  raw                Json
  promptVersion      String?
  modelUsed          String?
  createdAt          DateTime     @default(now())
  skillMatches       SkillMatch[]

  @@index([sessionId])
}

model SkillMatch {
  id                String        @id @default(cuid())
  sessionId         String
  session           TailoringSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  jdAnalysisId      String
  jdAnalysis        JdAnalysis    @relation(fields: [jdAnalysisId], references: [id], onDelete: Cascade)
  jdSkill           String
  priority          SkillPriority
  matchType         MatchType
  profileMatch      String?
  similarity        Float?
  riskLevel         RiskLevel
  recommendedAction String
  needsUserDecision Boolean
  evidenceQuote     String
  createdAt         DateTime      @default(now())

  @@index([sessionId])
}

model DecisionCard {
  id                 String         @id @default(cuid())
  sessionId          String
  session            TailoringSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  cardType           CardType
  severity           CardSeverity
  status             CardStatus     @default(pending)
  payload            Json
  autoResolvedOption String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  decisions          UserDecision[]

  @@index([sessionId])
}

model UserDecision {
  id                 String       @id @default(cuid())
  cardId             String
  card               DecisionCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  sessionId          String
  session            TailoringSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  optionId           String
  note               String?
  resolvedProvenance Provenance?
  createdAt          DateTime     @default(now())

  @@index([sessionId])
  @@index([cardId])
}

model ResumeStrategy {
  id                  String      @id @default(cuid())
  sessionId           String
  session             TailoringSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  payload             Json
  style               ResumeStyle @default(balanced)
  predictedMatchScore Int
  approved            Boolean     @default(false)
  promptVersion       String?
  modelUsed           String?
  createdAt           DateTime    @default(now())

  @@index([sessionId])
}

model GeneratedResume {
  id              String           @id @default(cuid())
  sessionId       String           @unique
  session         TailoringSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  activeVersionId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ResumeVersion {
  id               String            @id @default(cuid())
  sessionId        String
  session          TailoringSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  versionNo        Int
  contentJson      Json
  createdBy        CreatedBy
  matchScore       Int?
  atsScore         Int?
  recruiterScore   Int?
  riskLevel        RiskLevel?
  screeningOutlook ScreeningOutlook?
  validation       Json?
  createdAt        DateTime          @default(now())
  exports          ExportFile[]

  @@unique([sessionId, versionNo])
  @@index([sessionId])
}

model ExportFile {
  id         String        @id @default(cuid())
  versionId  String
  version    ResumeVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  format     ExportFormat
  storageKey String
  status     String        @default("processing")
  createdAt  DateTime      @default(now())
  expiresAt  DateTime?

  @@index([versionId])
}

model ChatMessage {
  id        String           @id @default(cuid())
  sessionId String
  session   TailoringSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime         @default(now())

  @@index([sessionId])
}

model AuditLog {
  id        String            @id @default(cuid())
  sessionId String?
  session   TailoringSession? @relation(fields: [sessionId], references: [id])
  userId    String?
  user      User?             @relation(fields: [userId], references: [id])
  eventType String
  fromState SessionState?
  toState   SessionState?
  payload   Json?
  createdAt DateTime          @default(now())

  @@index([sessionId])
}

// Admin-managed visual resume styles ("ResumeVisualStyle" — the ResumeStyle
// name is taken by the per-session content-style enum). Profiles reference a
// style by `key` inside baseResume.resumeStyle; config holds the enumerated
// visual tokens validated by @cotailor/shared styleConfigSchema.
model ResumeVisualStyle {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  config      Json
  enabled     Boolean  @default(true)
  isDefault   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---- Premium / config tables ----
model SkillTaxonomy {
  id           String   @id @default(cuid())
  skill        String   @unique
  family       String
  aliases      String[]
  earliestYear Int?
  sensitive    Boolean  @default(false)
}

model CategoryRelation {
  id        String               @id @default(cuid())
  categoryA String
  categoryB String
  relation  CategoryRelationKind

  @@unique([categoryA, categoryB])
}

model DecisionMemory {
  id         String     @id @default(cuid())
  profileId  String
  profile    Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  jdSkill    String
  optionId   String
  provenance Provenance
  createdAt  DateTime   @default(now())

  @@index([profileId])
}
