# Copy this file to .env (same folder) — it is read when the API starts.
#   cp apps/api/.env.example apps/api/.env
# Note: the API only reads env at startup; restart `pnpm dev` after changes.

# Postgres connection. These values match docker-compose.yml, so if you start
# the database with `pnpm run db:up` you can use this line unchanged.
DATABASE_URL="postgresql://cotailor:cotailor@127.0.0.1:5432/cotailor?schema=public"

# Port the NestJS API listens on (the web app expects 3001).
API_PORT=3001

# Any string works for local dev; use a strong random secret in production.
JWT_SECRET="dev-only-change-me"

# LLM provider: stub | gemini | openai
# "stub" needs no API key — instant mock responses, zero cost. Start with it.
LLM_PROVIDER="stub"

# Only needed when LLM_PROVIDER="gemini"
# GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.5-flash"

# Only needed when LLM_PROVIDER="openai"
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
