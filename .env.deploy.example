# CoTailor deploy config. Copy to .env.deploy, edit, then run:  bash deploy.sh
# A fresh environment needs: Node.js 20+, pnpm, and a running PostgreSQL.

# REQUIRED — point this at your Postgres (it must already exist & be reachable).
DATABASE_URL="postgresql://cotailor:cotailor@127.0.0.1:5432/cotailor?schema=public"

# Browser-facing API URL — must include the /api/v1 prefix. Baked into the
# web + admin builds, so it must be the URL a browser uses; for a public server
# put your domain, e.g.  NEXT_PUBLIC_API_URL="https://api.yourdomain.com/api/v1"
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

API_PORT=3001

# Leave blank to auto-generate & persist a strong secret on first run.
JWT_SECRET=""

# stub = offline, no keys, canned responses (default). Others need a key below.
# stub | gemini | openai | claude
LLM_PROVIDER="stub"
# GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.5-flash"
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
# ANTHROPIC_API_KEY=""

# Emails auto-promoted to admin + activated on sign-in. The seeded admin
# (wrenikey.dev@gmail.com) is already active; keep it here as a safety net.
ADMIN_EMAILS="wrenikey.dev@gmail.com"
