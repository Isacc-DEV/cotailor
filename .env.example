# ---- Database (Postgres via docker compose) ----
DATABASE_URL="postgresql://cotailor:cotailor@localhost:5432/cotailor?schema=public"

# ---- Queue (Redis via docker compose) ----
REDIS_URL="redis://localhost:6379"

# ---- API ----
API_PORT=3001
JWT_SECRET="dev-only-change-me"

# ---- LLM adapter ----
# stub = deterministic canned responses (no network, no cost) — default for dev.
# claude | openai | gemini require the matching key below.
LLM_PROVIDER="stub"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# ---- Web ----
NEXT_PUBLIC_API_URL="http://localhost:3001"
